<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.asuka.backend.mapper.AdminMapper">

    <select id="getByUsername" resultType="com.asuka.backend.pojo.entity.Admin">
        SELECT * FROM blog_admin WHERE username = #{username}
    </select>

    <select id="getById" resultType="com.asuka.backend.pojo.entity.Admin">
        SELECT * FROM blog_admin WHERE id = #{id}
    </select>

</mapper>
